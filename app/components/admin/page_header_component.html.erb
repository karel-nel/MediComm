<div class="mb-6 flex flex-wrap items-start justify-between gap-3">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight text-slate-900"><%= @title %></h1>
    <% if @subtitle.present? %>
      <p class="mt-1 text-sm text-slate-600"><%= @subtitle %></p>
    <% end %>
  </div>

  <% if content.present? %>
    <div>
      <%= content %>
    </div>
  <% end %>
</div>
