<section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
  <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-600"><%= @group_state.label %></h3>

  <div class="mt-4 space-y-3">
    <% @group_state.fields.each do |field_state| %>
      <div class="rounded-xl border border-slate-100 bg-slate-50/60 p-3">
        <div class="flex flex-wrap items-center justify-between gap-2">
          <p class="text-sm font-medium text-slate-900"><%= field_state.field.label %></p>
          <div class="flex items-center gap-2">
            <%= render Admin::StatusBadgeComponent.new(value: field_state.status) %>
            <%= render Admin::StatusBadgeComponent.new(value: confidence_bucket(field_state.confidence), context: :confidence) %>
            <% if editable?(field_state) %>
              <%= link_to "Correct",
                edit_admin_session_field_value_path(@intake_session, field_state.field_value),
                class: "rounded border border-slate-200 px-2 py-1 text-xs font-medium text-slate-600 hover:bg-slate-100" %>
            <% end %>
          </div>
        </div>
        <p class="mt-2 text-sm text-slate-700"><%= field_state.value_text %></p>
      </div>
    <% end %>
  </div>
</section>
