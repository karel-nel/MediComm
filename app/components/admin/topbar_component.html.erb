<header class="sticky top-0 z-10 border-b border-slate-200 bg-white/85 px-6 py-3 backdrop-blur lg:px-10">
  <div class="flex flex-wrap items-center gap-3">
    <div class="min-w-[14rem] flex-1 lg:max-w-xl">
      <label for="admin-search" class="sr-only">Search</label>
      <input id="admin-search" type="search" placeholder="Search sessions, files, or team members" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3.5 py-2 text-sm text-slate-700 placeholder:text-slate-400 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100">
    </div>

    <div class="hidden items-center gap-2 rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-600 lg:flex">
      <span class="font-semibold text-slate-800"><%= practice_label %></span>
      <span class="text-slate-400">•</span>
      <span><%= practice_slug %></span>
    </div>

    <div class="ml-auto flex items-center gap-3 rounded-xl border border-slate-200 bg-white px-3 py-1.5">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-teal-600 text-xs font-semibold text-white"><%= user_initials %></span>
      <div class="hidden sm:block">
        <p class="text-sm font-medium text-slate-900"><%= @user&.full_name.presence || "Account" %></p>
        <p class="text-xs text-slate-500"><%= @user&.email %></p>
      </div>
      <%= button_to "Log out",
        destroy_user_session_path,
        method: :delete,
        form: { class: "inline" },
        class: "rounded-lg border border-slate-200 px-2.5 py-1 text-xs font-medium text-slate-600 transition hover:bg-slate-100 hover:text-slate-800" %>
    </div>
  </div>
</header>
