<section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
  <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-600">Audit Trail</h3>

  <ul class="mt-4 space-y-3">
    <% if @events.any? %>
      <% @events.each do |event| %>
        <li class="rounded-xl border border-slate-100 bg-slate-50/70 p-3">
          <p class="text-sm font-medium text-slate-900"><%= event.event_type.humanize %></p>
          <p class="mt-1 text-xs text-slate-500"><%= l(event.created_at, format: :short) %></p>
          <% if event.payload_json.present? %>
            <p class="mt-2 text-xs text-slate-600"><%= event.payload_json.to_json %></p>
          <% end %>
        </li>
      <% end %>
    <% else %>
      <li class="text-sm text-slate-500">No audit entries recorded yet.</li>
    <% end %>
  </ul>
</section>
