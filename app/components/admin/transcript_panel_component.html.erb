<section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
  <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-600">Transcript</h3>

  <div class="mt-4 space-y-3">
    <% if @messages.any? %>
      <% @messages.each do |message| %>
        <% inbound = message.direction_inbound? %>
        <article class="max-w-[90%] rounded-2xl px-3 py-2 <%= inbound ? 'bg-slate-100 text-slate-800' : 'ml-auto bg-blue-600 text-white' %>">
          <p class="text-sm leading-relaxed"><%= message.text_body.presence || "(no text body)" %></p>
          <p class="mt-1 text-[11px] <%= inbound ? 'text-slate-500' : 'text-blue-100' %>">
            <%= inbound ? "Patient" : "System" %> • <%= l(message.created_at, format: :short) %>
          </p>
        </article>
      <% end %>
    <% else %>
      <p class="text-sm text-slate-500">No transcript entries yet.</p>
    <% end %>
  </div>
</section>
