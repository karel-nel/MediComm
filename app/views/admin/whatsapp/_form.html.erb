<%= form_with model: account, url: form_url, method: form_method, class: "space-y-5" do |f| %>
  <% if account.errors.any? %>
    <section class="rounded-2xl border border-rose-200 bg-rose-50 px-5 py-4">
      <h2 class="text-sm font-semibold text-rose-700">Please fix the following issues:</h2>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-rose-700">
        <% account.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <%= render Admin::PageSectionComponent.new(
    title: "WhatsApp Account",
    description: "Configuration only. Connectivity checks are implemented later."
  ) do %>
    <div class="grid gap-4 md:grid-cols-2">
      <div>
        <%= f.label :business_account_name, class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= f.text_field :business_account_name, class: "w-full rounded-xl border border-slate-200 px-3 py-2 text-sm text-slate-800 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
      </div>
      <div>
        <%= f.label :display_phone_number, class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= f.text_field :display_phone_number, class: "w-full rounded-xl border border-slate-200 px-3 py-2 text-sm text-slate-800 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
      </div>
      <div>
        <%= f.label :phone_number_id, "WhatsApp Phone Number ID", class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= f.text_field :phone_number_id, class: "w-full rounded-xl border border-slate-200 px-3 py-2 text-sm text-slate-800 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
        <p class="mt-1 text-xs text-slate-500">Example: 948579418347281</p>
      </div>
      <div>
        <%= f.label :waba_id, "WABA ID", class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= f.text_field :waba_id, class: "w-full rounded-xl border border-slate-200 px-3 py-2 text-sm text-slate-800 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
        <p class="mt-1 text-xs text-slate-500">Meta WhatsApp Business Account identifier</p>
      </div>
      <div class="md:col-span-2">
        <%= f.label :access_token_ciphertext, "Access Token", class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= f.password_field :access_token_ciphertext, autocomplete: "off", placeholder: account.persisted? ? "Leave blank to keep existing token" : "Paste access token", class: "w-full rounded-xl border border-slate-200 px-3 py-2 text-sm text-slate-800 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
        <% if account.persisted? %>
          <p class="mt-1 text-xs text-slate-500">
            <%= account.access_token_ciphertext.present? ? "Token currently stored." : "No token currently stored." %>
          </p>
        <% end %>
      </div>
      <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 md:col-span-2">
        <label class="inline-flex items-center gap-2 text-sm font-medium text-slate-700">
          <%= f.check_box :active, class: "rounded border-slate-300 text-blue-600 focus:ring-blue-200" %>
          <span>Account active</span>
        </label>
      </div>
    </div>
  <% end %>

  <div class="flex justify-end gap-2">
    <%= link_to "Cancel", admin_whatsapp_path, class: "rounded-xl border border-slate-200 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100" %>
    <%= f.submit submit_label, class: "rounded-xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-500" %>
  </div>
<% end %>
