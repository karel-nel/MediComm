<%= render Admin::PageHeaderComponent.new(
  title: "WhatsApp",
  subtitle: "Practice channel configuration and operational health"
) do %>
  <% if @account.present? %>
    <%= link_to "Edit Account", edit_admin_whatsapp_path, class: "rounded-xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-500" %>
  <% else %>
    <%= link_to "Add Account", new_admin_whatsapp_path, class: "rounded-xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-500" %>
  <% end %>
<% end %>

<%= render Admin::PageSectionComponent.new(
  title: "Channel Health",
  description: "Current channel availability for inbound intake conversations."
) do %>
  <div class="flex flex-wrap items-center gap-3">
    <%= render Admin::StatusBadgeComponent.new(value: @overview.health_label) %>
    <p class="text-sm text-slate-600"><%= @overview.status_note %></p>
  </div>
  <p class="mt-3 text-xs text-slate-500"><%= @overview.recent_session_count %> sessions started in the last 24 hours.</p>
<% end %>

<div class="mt-5">
  <%= render Admin::PageSectionComponent.new(
    title: "Configured Accounts",
    description: "Practice-scoped account details."
  ) do %>
    <% if @overview.accounts.any? %>
      <div class="space-y-3">
        <% @overview.accounts.each do |account| %>
          <article class="rounded-xl border border-slate-200 bg-slate-50/70 p-4">
            <div class="flex flex-wrap items-center justify-between gap-2">
              <div>
                <p class="text-sm font-semibold text-slate-900"><%= account.business_account_name.presence || "WhatsApp Business Account" %></p>
                <p class="mt-1 text-xs text-slate-500"><%= account.display_phone_number %> • phone_number_id: <%= account.phone_number_id %></p>
              </div>
              <%= render Admin::StatusBadgeComponent.new(value: account.active? ? "connected" : "failed") %>
            </div>
            <p class="mt-2 text-xs text-slate-500">waba_id: <%= account.waba_id %></p>
            <p class="mt-1 text-xs text-slate-500">
              webhook verify token: <%= account.webhook_verify_token.present? ? "configured" : "not set" %> •
              app secret: <%= account.app_secret_ciphertext.present? ? "configured" : "not set" %>
            </p>
          </article>
        <% end %>
      </div>
    <% else %>
      <%= render Admin::EmptyStateComponent.new(
        title: "No WhatsApp accounts configured",
        description: "Account setup and connectivity testing will be completed in the integration phases."
      ) %>
    <% end %>
  <% end %>
</div>
