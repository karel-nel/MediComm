<%= render Admin::PageHeaderComponent.new(
  title: "Files",
  subtitle: "Uploads and extracted artifacts"
) %>

<section class="mb-5 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
  <%= form_with url: admin_files_path, method: :get, class: "grid gap-3 md:grid-cols-[2fr_1fr_auto]" do |f| %>
    <div>
      <%= f.label :q, "Search", class: "mb-1 block text-xs font-semibold uppercase tracking-wide text-slate-600" %>
      <%= f.search_field :q, value: params[:q], placeholder: "File name, MIME type, or patient", class: "w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-700 placeholder:text-slate-400 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
    </div>
    <div>
      <%= f.label :processing_status, class: "mb-1 block text-xs font-semibold uppercase tracking-wide text-slate-600" %>
      <%= f.select :processing_status, options_for_select([["All", ""]] + @processing_statuses.map { |status| [status.humanize, status] }, params[:processing_status]), {}, class: "w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
    </div>
    <div class="flex items-end gap-2">
      <%= f.submit "Apply", class: "rounded-xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-500" %>
      <%= link_to "Reset", admin_files_path, class: "rounded-xl border border-slate-200 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100" %>
    </div>
  <% end %>
</section>

<% if @attachments.any? %>
  <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    <% @attachments.each do |attachment| %>
      <%= render Admin::FileCardComponent.new(attachment: attachment) %>
    <% end %>
  </section>
<% else %>
  <%= render Admin::EmptyStateComponent.new(
    title: "No files found",
    description: "Files linked to intake sessions will appear here once uploaded by patients."
  ) %>
<% end %>
