<%= render Admin::PageHeaderComponent.new(
  title: "Overview",
  subtitle: "Operational control center for #{current_practice.name}"
) do %>
  <%= render Admin::StatusBadgeComponent.new(value: current_practice.status) %>
<% end %>

<section class="grid gap-4 md:grid-cols-3">
  <%= render Admin::MetricCardComponent.new(label: "Total Sessions", value: @metrics.total_sessions, support_text: "Across all active intake flows", tone: :blue) %>
  <%= render Admin::MetricCardComponent.new(label: "Awaiting Review", value: @metrics.awaiting_review_sessions, support_text: "Requires staff decision", tone: :amber) %>
  <%= render Admin::MetricCardComponent.new(label: "Completed", value: @metrics.completed_sessions, support_text: "#{@metrics.active_flows} published flows", tone: :teal) %>
</section>

<section class="mt-5 grid gap-5 xl:grid-cols-[1.4fr_1fr]">
  <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <div class="mb-4 flex items-center justify-between gap-3">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-600">Recent Queue</h2>
      <%= link_to "View all sessions", admin_sessions_path, class: "text-xs font-medium text-blue-700 hover:text-blue-600" %>
    </div>
    <%= render Admin::SessionsTableComponent.new(sessions: @recent_queue) %>
  </article>

  <div class="space-y-5">
    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-600">WhatsApp Channel Health</h2>
      <div class="mt-3 flex items-center gap-2">
        <%= render Admin::StatusBadgeComponent.new(value: @channel_health[:status]) %>
      </div>
      <p class="mt-2 text-sm text-slate-600"><%= @channel_health[:detail] %></p>
    </article>

    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-600">Recent Activity</h2>
      <ul class="mt-4 space-y-3">
        <% @recent_activity.each do |event| %>
          <li class="rounded-xl border border-slate-100 bg-slate-50 p-3">
            <p class="text-sm font-medium text-slate-800"><%= event.event_type.humanize %></p>
            <p class="mt-1 text-xs text-slate-500">
              <%= event.intake_session.patient_display_name %> • <%= time_ago_in_words(event.created_at) %> ago
            </p>
          </li>
        <% end %>
      </ul>
    </article>
  </div>
</section>
