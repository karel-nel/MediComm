<%= render Admin::PageHeaderComponent.new(
  title: "Sessions",
  subtitle: "Patient intake conversations and review queue"
) %>

<section class="mb-5 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
  <%= form_with url: admin_sessions_path, method: :get, class: "grid gap-3 md:grid-cols-[2fr_1fr_1fr_1fr_auto]" do |f| %>
    <div>
      <%= f.label :q, "Search", class: "mb-1 block text-xs font-semibold uppercase tracking-wide text-slate-600" %>
      <%= f.search_field :q, value: params[:q], placeholder: "Patient name, phone, or reference", class: "w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-700 placeholder:text-slate-400 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
    </div>
    <div>
      <%= f.label :status, class: "mb-1 block text-xs font-semibold uppercase tracking-wide text-slate-600" %>
      <%= f.select :status, options_for_select([["All", ""]] + IntakeSession.statuses.keys.map { |s| [s.humanize, s] }, params[:status]), {}, class: "w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
    </div>
    <div>
      <%= f.label :flow_id, "Flow", class: "mb-1 block text-xs font-semibold uppercase tracking-wide text-slate-600" %>
      <%= f.select :flow_id, options_for_select([["All", ""]] + @flows.map { |flow| [flow.name, flow.id] }, params[:flow_id]), {}, class: "w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
    </div>
    <div>
      <%= f.label :confidence, class: "mb-1 block text-xs font-semibold uppercase tracking-wide text-slate-600" %>
      <%= f.select :confidence, options_for_select([["All", ""], ["High", "high"], ["Medium", "medium"], ["Low", "low"]], params[:confidence]), {}, class: "w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
    </div>
    <div class="flex items-end gap-2">
      <%= f.submit "Apply", class: "rounded-xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-500" %>
      <%= link_to "Reset", admin_sessions_path, class: "rounded-xl border border-slate-200 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100" %>
    </div>
  <% end %>
</section>

<%= render Admin::SessionsTableComponent.new(sessions: @sessions) %>
