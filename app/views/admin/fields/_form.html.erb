<%= form_with model: @field, url: form_url, method: form_method, class: "space-y-5" do |f| %>
  <% if @field.errors.any? %>
    <section class="rounded-2xl border border-rose-200 bg-rose-50 px-5 py-4">
      <h2 class="text-sm font-semibold text-rose-700">Please fix the following issues:</h2>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-rose-700">
        <% @field.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <%= render Admin::PageSectionComponent.new(
    title: "Field Configuration",
    description: "Schema-driven field definition used by intake orchestration."
  ) do %>
    <div class="grid gap-4 md:grid-cols-2">
      <div>
        <%= f.label :intake_field_group_id, "Field Group", class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= f.select :intake_field_group_id, options_for_select([["Ungrouped", nil]] + @flow.intake_field_groups.active.order(:position).map { |group| [group.label, group.id] }, @field.intake_field_group_id), {}, class: "w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm text-slate-800 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
      </div>
      <div>
        <%= f.label :field_type, class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= f.select :field_type, options_for_select(IntakeField::FIELD_TYPES.map { |type| [type.humanize, type] }, @field.field_type), {}, class: "w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm text-slate-800 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
      </div>
      <div>
        <%= f.label :key, class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= f.text_field :key, class: "w-full rounded-xl border border-slate-200 px-3 py-2 text-sm text-slate-800 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
      </div>
      <div>
        <%= f.label :label, class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= f.text_field :label, class: "w-full rounded-xl border border-slate-200 px-3 py-2 text-sm text-slate-800 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
      </div>
      <div>
        <%= f.label :ask_priority, class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= f.number_field :ask_priority, min: 0, class: "w-full rounded-xl border border-slate-200 px-3 py-2 text-sm text-slate-800 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
      </div>
      <div>
        <%= f.label :source_preference, class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= f.select :source_preference, options_for_select(IntakeField::SOURCE_PREFERENCES.map { |option| [option.humanize, option] }, @field.source_preference), {}, class: "w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm text-slate-800 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
      </div>
      <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2">
        <label class="inline-flex items-center gap-2 text-sm font-medium text-slate-700">
          <%= f.check_box :required, class: "rounded border-slate-300 text-blue-600 focus:ring-blue-200" %>
          <span>Required field</span>
        </label>
      </div>
      <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2">
        <label class="inline-flex items-center gap-2 text-sm font-medium text-slate-700">
          <%= f.check_box :extraction_enabled, class: "rounded border-slate-300 text-blue-600 focus:ring-blue-200" %>
          <span>Extraction enabled</span>
        </label>
      </div>
      <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2">
        <label class="inline-flex items-center gap-2 text-sm font-medium text-slate-700">
          <%= f.check_box :active, class: "rounded border-slate-300 text-blue-600 focus:ring-blue-200" %>
          <span>Field active</span>
        </label>
      </div>
      <div>
        <%= f.label :autofill_pdf_key, class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= f.text_field :autofill_pdf_key, class: "w-full rounded-xl border border-slate-200 px-3 py-2 text-sm text-slate-800 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
      </div>
      <div class="md:col-span-2">
        <%= f.label :ai_prompt_hint, class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= f.text_area :ai_prompt_hint, rows: 2, class: "w-full rounded-xl border border-slate-200 px-3 py-2 text-sm text-slate-800 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
      </div>
      <div>
        <%= label_tag "intake_field_validation_rules_text", "Validation Rules JSON", class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= text_area_tag "intake_field[validation_rules_text]", JSON.pretty_generate(@field.validation_rules_json || {}), rows: 5, class: "w-full rounded-xl border border-slate-200 px-3 py-2 font-mono text-xs text-slate-800 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
      </div>
      <div>
        <%= label_tag "intake_field_branching_rules_text", "Branching Rules JSON", class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= text_area_tag "intake_field[branching_rules_text]", JSON.pretty_generate(@field.branching_rules_json || {}), rows: 5, class: "w-full rounded-xl border border-slate-200 px-3 py-2 font-mono text-xs text-slate-800 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
      </div>
      <div>
        <%= label_tag "intake_field_skip_rules_text", "Skip Rules JSON", class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= text_area_tag "intake_field[skip_rules_text]", JSON.pretty_generate(@field.skip_rules_json || {}), rows: 5, class: "w-full rounded-xl border border-slate-200 px-3 py-2 font-mono text-xs text-slate-800 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
      </div>
      <div>
        <%= label_tag "intake_field_example_values_text", "Example Values JSON Array", class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= text_area_tag "intake_field[example_values_text]", JSON.pretty_generate(@field.example_values_json || []), rows: 5, class: "w-full rounded-xl border border-slate-200 px-3 py-2 font-mono text-xs text-slate-800 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
      </div>
    </div>
  <% end %>

  <div class="flex justify-end gap-2">
    <%= link_to "Cancel", admin_flow_path(@flow), class: "rounded-xl border border-slate-200 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100" %>
    <%= f.submit submit_label, class: "rounded-xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-500" %>
  </div>
<% end %>
