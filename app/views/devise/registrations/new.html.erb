<div class="mx-auto max-w-5xl">
  <div class="grid gap-6 rounded-3xl border border-slate-200 bg-white p-6 shadow-sm lg:grid-cols-[1.1fr_1fr] lg:p-10">
    <section class="rounded-2xl bg-gradient-to-br from-slate-900 via-slate-800 to-teal-900 p-6 text-slate-100">
      <p class="text-xs font-semibold uppercase tracking-[0.14em] text-teal-200">MediComm</p>
      <h1 class="mt-4 text-3xl font-semibold tracking-tight">Create Your Practice Workspace</h1>
      <p class="mt-3 text-sm leading-relaxed text-slate-200">
        Start with one owner account for your practice. All data in the admin app will be scoped to your practice tenancy.
      </p>
      <ul class="mt-6 space-y-2 text-sm text-slate-100/90">
        <li>One secure login for the practice owner</li>
        <li>Admin shell ready for operations workflows</li>
        <li>Designed for a calm desktop working environment</li>
      </ul>
    </section>

    <section>
      <h2 class="text-xl font-semibold text-slate-900">Sign up</h2>
      <p class="mt-1 text-sm text-slate-600">Create your owner account and practice.</p>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "mt-5 space-y-4" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <%= f.label :first_name, class: "mb-1 block text-sm font-medium text-slate-700" %>
            <%= f.text_field :first_name, autofocus: true, class: "w-full rounded-xl border border-slate-200 px-3 py-2 text-sm text-slate-800 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
          </div>

          <div>
            <%= f.label :last_name, class: "mb-1 block text-sm font-medium text-slate-700" %>
            <%= f.text_field :last_name, class: "w-full rounded-xl border border-slate-200 px-3 py-2 text-sm text-slate-800 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
          </div>
        </div>

        <div>
          <%= f.label :practice_name, class: "mb-1 block text-sm font-medium text-slate-700" %>
          <%= f.text_field :practice_name, class: "w-full rounded-xl border border-slate-200 px-3 py-2 text-sm text-slate-800 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
        </div>

        <div>
          <%= f.label :email, class: "mb-1 block text-sm font-medium text-slate-700" %>
          <%= f.email_field :email, autocomplete: "email", class: "w-full rounded-xl border border-slate-200 px-3 py-2 text-sm text-slate-800 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
        </div>

        <div>
          <%= f.label :password, class: "mb-1 block text-sm font-medium text-slate-700" %>
          <% if @minimum_password_length %>
            <p class="mb-1 text-xs text-slate-500"><%= @minimum_password_length %> characters minimum</p>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", class: "w-full rounded-xl border border-slate-200 px-3 py-2 text-sm text-slate-800 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
        </div>

        <div>
          <%= f.label :password_confirmation, class: "mb-1 block text-sm font-medium text-slate-700" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full rounded-xl border border-slate-200 px-3 py-2 text-sm text-slate-800 focus:border-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-100" %>
        </div>

        <div>
          <%= f.submit "Create Practice", class: "w-full rounded-xl bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-500" %>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </section>
  </div>
</div>
