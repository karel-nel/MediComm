<% flash.each do |type, message| %>
  <% next if message.blank? %>
  <% tone = type.to_s == "alert" ? "border-rose-200 bg-rose-50 text-rose-700" : "border-emerald-200 bg-emerald-50 text-emerald-700" %>
  <div class="mb-3 rounded-xl border px-4 py-3 text-sm <%= tone %>">
    <%= message %>
  </div>
<% end %>
